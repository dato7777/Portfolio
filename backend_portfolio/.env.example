# Copy this file to .env and fill in your values:
#   cp backend_portfolio/.env.example backend_portfolio/.env

# --- QuizProAI (OpenAI question generation) ---
OPENAI_API_KEY=sk-your-openai-key

# --- Weather Lab ---
OPENWEATHER_API_KEY=your-openweather-key
RAPIDAPI_KEY=your-rapidapi-key

# --- Auth (use a long random string in production) ---
JWT_SECRET_KEY=change-me-to-a-long-random-secret

# --- Database (optional — SQLite defaults work for local dev) ---
# DATABASE_URL=sqlite:///backend_portfolio/quiz.db
# SQLITE_PATH=backend_portfolio/quiz.db
