# Copy this file to .env and fill in your values:
#   cp backend_portfolio/.env.example backend_portfolio/.env

# --- Supabase PostgreSQL (recommended for production — data persists) ---
# Supabase → Project Settings → Database → Connection string → URI (Session mode)
# Paste your full URL below (replace [YOUR-PASSWORD]).
# If password contains $ or !, URL-encode them (%24, %21) OR avoid `source .env` in bash.
DATABASE_URL=postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
# Buy Smart uses the same DB by default. Override only if you use a second database:
# BUY_SMART_DATABASE_URL=

# --- Local SQLite fallback (used only when DATABASE_URL is not set) ---
# SQLITE_PATH=backend_portfolio/quiz.db
# BUY_SMART_SQLITE_PATH=backend_portfolio/buy_smart.db

# --- QuizProAI (OpenAI question generation) ---
OPENAI_API_KEY=sk-your-openai-key

# --- Weather Lab ---
OPENWEATHER_API_KEY=your-openweather-key
RAPIDAPI_KEY=your-rapidapi-key

# --- Auth (use a long random string in production) ---
JWT_SECRET_KEY=change-me-to-a-long-random-secret

# --- Supabase Auth JWT verification (Project Settings → API) ---
# JWT Secret: used to verify Supabase access tokens on /auth/signup and /auth/sync
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# Project URL (optional but recommended for issuer check), e.g. https://xxxx.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# --- CORS (comma-separated; required for Vercel frontend) ---
# ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
# FRONTEND_URL=https://your-app.vercel.app

# --- Optional ---
# SQL_ECHO=true
# Buy Smart: db = search Supabase (default). live = scrape Hetzi on each search (local dev only).
# BUY_SMART_SEARCH_MODE=db
