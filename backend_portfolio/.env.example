# Copy this file to .env and fill in your values:
#   cp backend_portfolio/.env.example backend_portfolio/.env

# --- QuizProAI (OpenAI question generation) ---
OPENAI_API_KEY=sk-your-openai-key

# --- Weather Lab ---
OPENWEATHER_API_KEY=your-openweather-key
RAPIDAPI_KEY=your-rapidapi-key

# --- Auth (use a long random string in production) ---
JWT_SECRET_KEY=change-me-to-a-long-random-secret

# --- CORS (comma-separated; required for Vercel frontend) ---
# ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
# Or set a single production URL:
# FRONTEND_URL=https://your-app.vercel.app

# --- Database (optional locally; use /data paths on Render with persistent disk) ---
# DATABASE_URL=sqlite:///backend_portfolio/quiz.db
# SQLITE_PATH=backend_portfolio/quiz.db
# BUY_SMART_SQLITE_PATH=backend_portfolio/buy_smart.db
# Render example:
# SQLITE_PATH=/data/quiz.db
# BUY_SMART_SQLITE_PATH=/data/buy_smart.db
